# AWS credentials — required only when S3_ENABLED=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET=

# Storage toggles
S3_ENABLED=false
LOCAL_ENABLED=true

# ML classification (Modulhandbuch classifier)
# When true, each downloaded document is scored by the trained model and the
# verdict is written to output/_review/manifest_<job_id>.jsonl. Requires the
# mlclassifier package + its deps (scikit-learn, pymupdf, pandas) to be
# installed in the same environment; otherwise it safely no-ops.
CLASSIFIER_ENABLED=false
# Path to the trained model artifact. Empty → mlclassifier's default location
# (<repo>/mlclassifier/artifacts/module_classifier.joblib).
MODEL_PATH=

# Scrapy behaviour
DOWNLOAD_DELAY=1
CONCURRENT_REQUESTS=4
USER_AGENT=webscraper/1.0 (+https://github.com/yourorg/webscraper)

# Logging
LOG_LEVEL=INFO

# Web app (FastAPI admin frontend) — required for the Scraping tab to trigger
# the deployed Lambda. AWS credentials/region come from the AWS_* vars above
# (on EC2, prefer an IAM instance role over static keys).
LAMBDA_FUNCTION_NAME=webscraper
# AWS_REGION falls back to AWS_DEFAULT_REGION if unset.
AWS_REGION=eu-central-1

# --- HTTPS reverse proxy (Caddy) ---
# Public address the app is served at — the Elastic IP (or a domain if you have
# one). Used by Caddy to provision the self-signed certificate. REQUIRED.
SITE_ADDRESS=63.183.184.19

# --- Authentication / session security (REQUIRED for deployment) ---
# Signing key for session tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Session lifetime in seconds (default 12h).
SESSION_MAX_AGE_SECONDS=43200
# Initial administrator credentials — ONLY applied when the DB is first created.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# --- Persistent storage paths (set automatically in Docker) ---
# Override the SQLite DB location if needed (default: <project>/app.db)
# APP_DB_PATH=
# Override the scrape log file location (default: <project>/Log.txt)
# LOG_FILE=
# Override the uploaded-models directory (default: <project>/SYS_AI_MODELS)
# MODELS_DIR=
